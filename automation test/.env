# =============================================================================
# RevOps Automation — Environment Variables
# Fill in all values before running any script.
# Never commit this file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# SALESFORCE (Connected App / OAuth2 credentials)
# Docs: https://developer.salesforce.com/docs/atlas.en-us.api_rest.meta/api_rest
# -----------------------------------------------------------------------------

# Your Salesforce org login URL.
# Production: https://login.salesforce.com
# Sandbox:    https://test.salesforce.com
SF_INSTANCE_URL=https://checkout.lightning.force.com/lightning/page/home

# Username of the Salesforce user the scripts will run as.
SF_USERNAME=eliza.chew@checkout.com

# Password for SF_USERNAME (combined with security token below).
SF_PASSWORD=21Finucanecres!

# Security token appended to the password for IP-restricted orgs.
# Retrieve from: Salesforce > Settings > Reset My Security Token
SF_SECURITY_TOKEN=O6Uf3Fm0vkxXTLC9jnV97cvd

# Consumer Key from your Salesforce Connected App.
SF_CLIENT_ID=

# Consumer Secret from your Salesforce Connected App.
SF_CLIENT_SECRET=

# API version to use (e.g. 59.0). Leave blank to use the library default.
SF_API_VERSION=59.0

# -----------------------------------------------------------------------------
# APOLLO.IO (Prospecting & enrichment)
# Docs: https://apolloio.github.io/apollo-api-docs/
# -----------------------------------------------------------------------------

# Apollo API key — found under Apollo > Settings > Integrations > API.
APOLLO_API_KEY=

# Base URL for Apollo API (rarely needs changing).
APOLLO_BASE_URL=https://api.apollo.io/v1

# Max records to pull per Apollo API request (default 100, max 200).
APOLLO_PAGE_SIZE=100

# -----------------------------------------------------------------------------
# LOOKER (Business intelligence & dashboards)
# Docs: https://developers.looker.com/api/explorer/
# -----------------------------------------------------------------------------

# Base URL of your Looker instance, no trailing slash.
# Example: https://yourcompany.looker.com
LOOKER_BASE_URL=

# Looker API client ID (from Admin > Users > API Keys).
LOOKER_CLIENT_ID=

# Looker API client secret paired with the client ID above.
LOOKER_CLIENT_SECRET=

# Looker API port (default 19999 for older instances; modern: 443).
LOOKER_PORT=19999

# -----------------------------------------------------------------------------
# TERRITORY / POD ASSIGNMENT CONFIG
# -----------------------------------------------------------------------------

# Path to the pod manifest JSON that defines territory rules.
POD_MANIFEST_PATH=./pod_manifest_template.json

# Salesforce custom field API name on the Account object for territory.
SF_TERRITORY_FIELD=Territory__c

# Salesforce custom field API name on the Account object for pod.
SF_POD_FIELD=Pod__c

# Salesforce custom field API name on the Account object for segment.
SF_SEGMENT_FIELD=Segment__c

# Salesforce custom field API name on the Account object for region.
SF_REGION_FIELD=Region__c

# Salesforce custom field API name on the Account object for account tier.
SF_ACCOUNT_TIER_FIELD=Account_Tier__c

# -----------------------------------------------------------------------------
# MEDDIC AUDIT CONFIG
# -----------------------------------------------------------------------------

# Comma-separated Salesforce Opportunity stage names to include in the audit.
# Example: Qualification,Discovery,Proposal,Negotiation
MEDDIC_TARGET_STAGES=Qualification,Discovery,Proposal,Negotiation,Closing

# Minimum MEDDIC score (0–6) below which an opportunity is flagged as at-risk.
MEDDIC_MIN_SCORE=3

# Salesforce custom field API names for each MEDDIC dimension on Opportunity.
SF_MEDDIC_METRICS_FIELD=Metrics__c
SF_MEDDIC_ECONOMIC_BUYER_FIELD=Economic_Buyer__c
SF_MEDDIC_DECISION_CRITERIA_FIELD=Decision_Criteria__c
SF_MEDDIC_DECISION_PROCESS_FIELD=Decision_Process__c
SF_MEDDIC_IDENTIFY_PAIN_FIELD=Identify_Pain__c
SF_MEDDIC_CHAMPION_FIELD=Champion__c
SF_MEDDIC_SCORE_FIELD=MEDDIC_Score__c

# -----------------------------------------------------------------------------
# GENERAL SCRIPT BEHAVIOR
# -----------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Directory where CSV/JSON output reports are written.
OUTPUT_DIR=./output

# Maximum Salesforce records to process in a single bulk API batch.
BATCH_SIZE=200
